{
  "name": "call-score",
  "version": "0.1.0",
  "description": "Open-source sales-call coaching framework. Run any transcript through classification, outcome inference, and structured MEDDPICC + Command-of-Message coaching, then mine a playbook across calls.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/salesgraph-inc/call-score.git"
  },
  "keywords": [
    "sales",
    "coaching",
    "meddpicc",
    "command-of-the-message",
    "gtm",
    "call-analysis",
    "transcript",
    "llm"
  ],
  "bin": {
    "call-score": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "packs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.77.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
